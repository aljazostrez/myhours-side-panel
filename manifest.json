{
  "manifest_version": 3,
  "name": "My Hours",
  "version": "1.0.0",
  "description": "My Hours webapp running as a browser Side Panel.",
  "browser_specific_settings": {
    "gecko": {
      "id": "myhours-side-panel@extension",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "declarativeNetRequest",
    "sidePanel"
  ],
  "host_permissions": [
    "https://app.myhours.com/*",
    "https://login.myhours.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "MyHoursIcon.png",
    "48": "MyHoursIcon.png",
    "128": "MyHoursIcon.png"
  },
  "action": {
    "default_title": "Open My Hours",
    "default_icon": "MyHoursIcon.png"
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "sidebar_action": {
    "default_title": "My Hours",
    "default_panel": "app.html",
    "default_icon": "MyHoursIcon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://app.myhours.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
